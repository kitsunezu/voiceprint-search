# Database
DB_PASSWORD=voiceprint

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production

# AI Service (set these if running frontend outside Docker)
AI_SERVICE_URL=http://localhost:8000

# Separator / Search tuning
PREPROCESS_NORMALIZE_MAX_SECONDS=45
